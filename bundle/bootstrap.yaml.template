schema_version: 1
contract:
  source_url: "https://raw.githubusercontent.com/<owner>/claude-bs-skill/v1.4.0/contract.md"
  source_tag: "v1.4.0"
  source_commit: "<40-hex-git-sha>"
  source_sha256: "<64-hex>"
  sha256_path: .bootstrap/contract.sha256
  compatible_range: ">=1.3, <2.0"
backlog: .bootstrap/backlog.yaml
ledger: docs/ops/dogfood-log.md
cycle_dir_root: .prompts/dogfood
workflow_dir: null
red_lines: []
verify_command: "bash scripts/verify-docs.sh" # deprecated final smoke; per-round Grade uses grade_verify.py
verify:
  grade:
    docs:
      - "bash scripts/verify-docs.sh"
    # code:
    #   - "RUSTC_WRAPPER= cargo build --workspace"
    #   - "RUSTC_WRAPPER= cargo clippy --workspace --all-targets -- -D warnings"
    #   - "RUSTC_WRAPPER= cargo nextest run --workspace"
  env:
    clear:
      - RUSTC_WRAPPER
      - SCCACHE_DIR
      - SCCACHE_CACHE_SIZE
preflight:
  require_council: false
  council_quorum_min: 2
  council_required_when: {}
register_prefixes: []
agent_prompts:
  shape_role: null
  shape_critic: null
  grade_role: null
  grade_critic: null
  conduct_critic: null
  reflection_role: null
